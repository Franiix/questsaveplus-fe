{
	"cli": {
		"version": ">= 18.6.0",
		"appVersionSource": "local"
	},
	"build": {
		"development": {
			"environment": "development",
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"environment": "preview",
			"distribution": "internal"
		},
		"production-ios": {
			"environment": "production",
			"autoIncrement": true,
			"env": {
				"APP_VERSION": "0.0.2"
			}
		},
		"production-android": {
			"environment": "production",
			"autoIncrement": true,
			"env": {
				"APP_VERSION": "0.0.4"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
