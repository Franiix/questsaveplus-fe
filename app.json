{
	"expo": {
		"name": "QuestSave+",
		"slug": "questsave-plus",
		"version": "0.0.1-alpha",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "questsave",
		"userInterfaceStyle": "automatic",
		"splash": {
			"image": "./assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#0F0F1A"
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.franiix.questsaveplus",
			"buildNumber": "1"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#0F0F1A"
			},
			"package": "com.franiix.questsaveplus",
			"versionCode": 1
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": ["expo-router", "expo-font", "expo-secure-store", "expo-localization"],
		"experiments": {
			"typedRoutes": true
		}
	}
}
