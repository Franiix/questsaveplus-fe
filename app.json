{
	"expo": {
		"name": "QuestSave+",
		"slug": "questsave-plus",
		"description": "Discover games powered by IGDB and track your personal backlog across mobile devices.",
		"version": "0.0.8",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "questsave",
		"userInterfaceStyle": "automatic",
		"splash": {
			"image": "./assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#0F0F1A"
		},
		"ios": {
			"supportsTablet": false,
			"bundleIdentifier": "com.franiix.questsaveplus",
			"buildNumber": "12",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"softwareKeyboardLayoutMode": "resize",
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#0F0F1A"
			},
			"blockedPermissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
			"package": "com.franiix.questsaveplus",
			"versionCode": 10
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			"expo-font",
			"expo-secure-store",
			"expo-localization",
			"./plugins/withAndroidReleaseStability",
			[
				"expo-image-picker",
				{
					"photosPermission": "QuestSave+ needs access to your photo library so you can choose a profile picture.",
					"cameraPermission": false,
					"microphonePermission": false
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "0c5df1ee-d8fd-48b4-bce3-b2375b676978"
			}
		},
		"owner": "franiix"
	}
}
